:{$PORT} {
    encode gzip

    handle_path /static/* {
        root * /app/wanshitong/static
        file_server
        header Cache-Control "public, max-age=86400"
        header -Server
    }

    reverse_proxy 127.0.0.1:9099 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}
